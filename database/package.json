{
  "name": "database",
  "version": "1.0.0",
  "private": true,
  "description": "PostgreSQL schema, migrations, and seeds for Support Ticket Management System",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:preflight": "bash scripts/preflight.sh",
    "db:setup": "bash scripts/setup.sh",
    "db:migrate": "bash scripts/preflight.sh && prisma migrate deploy",
    "db:seed": "bash scripts/preflight.sh && prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "db:verify": "bash scripts/verify.sh",
    "pretest": "node scripts/check-node.mjs",
    "test": "node scripts/check-node.mjs && vitest run --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "engines": {
    "node": ">=18.18"
  }
}
